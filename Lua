local function CreateESPForPlayer(player)
    if ESPObjects[player] then return end
    local function NL() local l=Drawing.new("Line");l.Thickness=1.5;l.Color=ESPCfg.BoxColor;l.Visible=false;return l end
    local lines={};for _=1,12 do table.insert(lines,NL()) end
