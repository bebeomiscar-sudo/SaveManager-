    local dl=Drawing.new("Text");dl.Size=11;dl.Center=true;dl.Outline=true;dl.Color=Color3.fromRGB(200,200,200);dl.Visible=false
    ESPObjects[player]={Lines=lines,FilledBox=fb,NameLabel=nl,HealthLabel=hl,DistLabel=dl}
