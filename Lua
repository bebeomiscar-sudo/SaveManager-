-- ── Advanced AutoShoot — from source ──────────────────────
local function AutoShoot(targetChar, item, lf)
    if not RageCfg.Enabled then return end
    if rageState.immune then return end
    if not targetChar or not ValidChar(targetChar) then return end
    if not CanFire(item) then
        -- Auto reload
        TriggerReload(item)
        return
    end

    local hitPart = HitPartFromName(targetChar, RageCfg.HitPart)
    if not hitPart then return end

    -- Compute shoot position
    -- Uses orbit server position if CSync active, else camera position
    local shootPos = Vector3.new()
    if orbitState.active and orbitState.serverPos ~= Vector3.new() then
        shootPos = orbitState.serverPos
    else
        local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        shootPos = myRoot and myRoot.Position or cam.CFrame.Position
    end

    -- Predicted target position
    local targetPos = RageCfg.PredictionOn
        and Predict(hitPart, shootPos)
        or  hitPart.Position

    -- Build network shot data
    local data = {
        [utf8.char(1)] = {
            [utf8.char(0)] = UtilityModule:EncodeCFrame(
                CFrame.new(shootPos, targetPos)
            ),
            [utf8.char(1)] = UtilityModule:EncodeCFrame(
                CFrame.new(shootPos, targetPos)
            ),
            [utf8.char(2)] = hitPart,
            [utf8.char(3)] = UtilityModule:EncodeCFrame(
                CFrame.new(0.43, 0.25, 0.42)
            ),
        },
    }

    local equipped = lf.EquippedItem
    if not equipped then return end
    local objectId = equipped:Get("ObjectID")
    if not objectId then return end

    rageState.lastAttack = tick()

    local attempts = math.clamp(
        math.floor(tonumber(RageCfg.ShootAttempts) or 1),
        1, 3
    )

    for _ = 1, attempts do
        pcall(function()
            UseItemRemote:FireServer(
                objectId,
                EnumsModule:ToEnum("StartShooting"),
                data,
                nil
            )
        end)
    end

    -- DoubleTap
    if RageCfg.DoubleTap then
        task.delay(RageCfg.DoubleTapDelay, function()
            if not hitPart or not hitPart.Parent then return end
            local hum = targetChar:FindFirstChildOfClass("Humanoid")
            if not hum or hum.Health <= 0 then return end

            local offset = Vector3.new(
                math.random(-5,5)*0.01,
                math.random(-5,5)*0.01,
                math.random(-5,5)*0.01
            )
            local data2 = {
                [utf8.char(1)] = {
                    [utf8.char(0)] = UtilityModule:EncodeCFrame(CFrame.new(shootPos+offset, targetPos)),
                    [utf8.char(1)] = UtilityModule:EncodeCFrame(CFrame.new(shootPos+offset, targetPos)),
                    [utf8.char(2)] = hitPart,
                    [utf8.char(3)] = UtilityModule:EncodeCFrame(CFrame.new(0.43, 0.25, 0.42)),
                },
            }
            pcall(function()
                UseItemRemote:FireServer(
                    objectId,
                    EnumsModule:ToEnum("StartShooting"),
                    data2,
                    nil
                )
            end)
        end)
    end
end

-- ── Orbit Base position computation ───────────────────────
local function OrbBase(targetRoot)
    if not targetRoot then return Vector3.new() end
    return targetRoot.Position
end

-- ── Stop CSync/Orbit ──────────────────────────────────────
local function StopCSync()
    rageState.csyncActive = false
    orbitState.active     = false
    orbitState.serverPos  = Vector3.new()
    if orbitState.connection then
        orbitState.connection:Disconnect()
        orbitState.connection = nil
    end
end

-- ── Start CSync/Orbit — from source ──────────────────────
local function StartCSync(targetChar)
    StopCSync()
    rageState.csyncActive = true
    orbitState.active     = true
    orbitState.angle      = 0

    orbitState.connection = Track(RunService.Heartbeat:Connect(function(dt)
        if not rageState.csyncActive then StopCSync();return end
        if rageState.immune then StopCSync();return end
        if not targetChar or not ValidChar(targetChar) then StopCSync();return end

        local myChar = lp.Character
        if not myChar then StopCSync();return end

        local localFighterEntity = nil
        pcall(function()
            if FighterController and FighterController.LocalFighter then
                localFighterEntity = FighterController.LocalFighter.Entity
            end
        end)

        -- Void/hide phase — teleport to random void coords
        if RageCfg.VoidSpam and rageState.voidPhase == "hide" then
            local randomX = math.random(-10000, 10000)
            local randomZ = math.random(-10000, 10000)
            orbitState.serverPos = Vector3.new(randomX, -99999999, randomZ)
            pcall(function()
                if localFighterEntity and localFighterEntity.RootPart then
                    localFighterEntity.RootPart.CFrame = CFrame.new(orbitState.serverPos)
                else
                    local hrp = myChar:FindFirstChild("HumanoidRootPart")
                    if hrp then hrp.CFrame = CFrame.new(orbitState.serverPos) end
                end
            end)
            return
        end

        -- Normal orbit — circle around target
        local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
        if not targetHRP then return end

        local targetPos = OrbBase(targetHRP)
        orbitState.angle = orbitState.angle + (RageCfg.OrbitSpeed * dt)

        local offset = Vector3.new(
            math.cos(orbitState.angle) * RageCfg.OrbitRadius,
            RageCfg.OrbitHeight,
            math.sin(orbitState.angle) * RageCfg.OrbitRadius
        )
        orbitState.serverPos = targetPos + offset

        -- Move character to orbit position
        local newCF   = CFrame.new(orbitState.serverPos)
        pcall(function()
            if localFighterEntity and localFighterEntity.RootPart then
                local dist = (newCF.Position - localFighterEntity.RootPart.Position).Magnitude
                if dist < 2000 then
                    localFighterEntity.RootPart.CFrame = newCF
                end
            else
                local hrp = myChar:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (newCF.Position - hrp.Position).Magnitude
                    if dist < 2000 then hrp.CFrame = newCF end
                end
            end
        end)
    end))
end

-- ── VoidSpam hide shot trigger ─────────────────────────────
local function HideShot()
    if not RageCfg.VoidSpam then return end
    rageState.voidPhase = "hide"
    task.delay(RageCfg.HideRange, function()
        rageState.voidPhase = "attack"
        task.delay(RageCfg.AttackRange, function()
            rageState.voidPhase = "idle"
        end)
    end)
end

-- ── Main ragebot heartbeat loop ────────────────────────────
local function StartRagebot()
    if rageConn then rageConn:Disconnect();rageConn=nil end
    rageState.running = false

    rageConn = Track(RunService.Heartbeat:Connect(function()
        if not RageCfg.Enabled or rageState.running then return end

        local lf, item = GetEquipped()
        if not lf or not item then return end

        local targetChar = RageGetTarget()
        if not targetChar then
            RageCfg.Phase = "idle"
            -- Stop orbit if no target
            if orbitState.active then StopCSync() end
            return
        end

        -- Start/maintain orbit if CSync enabled
        if RageCfg.CSyncEnabled and not orbitState.active then
            StartCSync(targetChar)
        elseif not RageCfg.CSyncEnabled and orbitState.active then
            StopCSync()
        end

        -- VoidSpam hide phase — skip shooting
        if RageCfg.VoidSpam and rageState.voidPhase == "hide" then
            RageCfg.Phase = "hiding"
            return
        end

        RageCfg.Phase     = "attacking"
        rageState.running = true

        task.spawn(function()
            local ok, err2 = pcall(function()
                -- Advanced autoshoot from source
                AutoShoot(targetChar, item, lf)
                -- Trigger hide after shot if voidspam
                HideShot()
                task.wait(RageCfg.AttackRange)
            end)

            if not ok then
                warn("[Ragebot] Error: " .. tostring(err2))
            end

            RageCfg.Phase     = "idle"
            rageState.running = false
        end)
    end))
end

local function StopRagebot()
    if rageConn then rageConn:Disconnect();rageConn=nil end
    StopCSync()
    RageCfg.Enabled   = false
    RageCfg.Phase     = "idle"
    rageState.running = false
    rageState.voidPhase = "idle"
end

