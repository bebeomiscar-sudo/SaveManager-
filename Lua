local function GetBoundingBox2D(char)
    local hrp=char:FindFirstChild("HumanoidRootPart")
    if not hrp then return nil end
    local ok,cf,size=pcall(function() return char:GetBoundingBox() end)
    local halfW=ok and (size.X/2) or 1.1
    local halfH=ok and (size.Y/2) or 1.5
    local center=hrp.Position
    local corners3D={
        center+Vector3.new(-halfW,-halfH,-halfW),center+Vector3.new(halfW,-halfH,-halfW),
        center+Vector3.new(halfW,-halfH,halfW),  center+Vector3.new(-halfW,-halfH,halfW),
        center+Vector3.new(-halfW,halfH,-halfW),  center+Vector3.new(halfW,halfH,-halfW),
        center+Vector3.new(halfW,halfH,halfW),    center+Vector3.new(-halfW,halfH,halfW),
    }
    local screen={}
    for _,c in ipairs(corners3D) do
        local sp,onScreen=cam:WorldToViewportPoint(c)
        if not onScreen then return nil end
        table.insert(screen,Vector2.new(sp.X,sp.Y))
    end
    return screen
