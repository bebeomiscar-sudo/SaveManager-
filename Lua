local MagicBulletObj = nil
local wbMagicObj     = nil

local function BuildMagicBulletObj(isAuto)
    if getgenv().__MagicBullet then
        pcall(function() getgenv().__MagicBullet:Shutdown() end)
        getgenv().__MagicBullet = nil
    end

    if not GunModule or not UtilityModule then
        warn("[MagicBullet] Missing modules")
        return nil
    end

    local oldShoot = GunModule.StartShooting
    if not oldShoot then
        warn("[MagicBullet] StartShooting not found")
        return nil
    end

    local obj = {
        __active=true,__target=nil,__desync=false,__curr=nil,
        __conn1=nil,__conn2=nil,__task1=nil,__oldfunc=oldShoot,
    }

    local function findTarget()
        local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot then return nil end
        local best,bd = nil,math.huge
        for _,p in next,Players:GetPlayers() do
            if p==lp then continue end
            if SameTeam(p) then continue end
            local char=p.Character;if not char then continue end
            local root=char:FindFirstChild("HumanoidRootPart")
            local head=char:FindFirstChild("Head")
            local hum=char:FindFirstChildWhichIsA("Humanoid")
            if not(root and head and hum and hum.Health>0) then continue end
            local d=(myRoot.Position-root.Position).Magnitude
            if d>200 then continue end
            if d<bd then bd=d;best=p end
        end
        return best
    end

    function obj:__desync_start(tp)
        if self.__conn2 then self.__conn2:Disconnect() end
        self.__desync=true;self.__curr=tp
        self.__conn2=Track(RunService.Heartbeat:Connect(function()
            if not self.__desync then return end
            local myRoot=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not myRoot then return end
            local tc=tp.Character
            local tHRP=tc and tc:FindFirstChild("HumanoidRootPart")
            if not tHRP then self:__desync_stop();return end
            local sCF=myRoot.CFrame;local sV=myRoot.AssemblyLinearVelocity;local sRV=myRoot.AssemblyAngularVelocity
            myRoot.CFrame=tHRP.CFrame*CFrame.new(0,-5,0)
            RunService:BindToRenderStep("__mbRestore",101,function()
                pcall(function() myRoot.CFrame=sCF;myRoot.AssemblyLinearVelocity=sV;myRoot.AssemblyAngularVelocity=sRV end)
                RunService:UnbindFromRenderStep("__mbRestore")
            end)
        end))
    end

    function obj:__desync_stop()
        self.__desync=false;self.__curr=nil
        if self.__conn2 then self.__conn2:Disconnect();self.__conn2=nil end
        RunService:UnbindFromRenderStep("__mbRestore")
    end

    local function buildSD(sd,head)
        local hp=head.Position;local hcf=head.CFrame
        local sp=hp-Vector3.new(0,5,0);local ac=CFrame.lookAt(sp,hp)
        sd[utf8.char(0)]=UtilityModule:EncodeCFrame(CFrame.new(sp,hp)*CFrame.Angles(ac:ToOrientation()))
        sd[utf8.char(1)]=UtilityModule:EncodeCFrame(CFrame.new(hp)*CFrame.Angles(ac:ToOrientation()))
        sd[utf8.char(2)]=head
        sd[utf8.char(3)]=UtilityModule:EncodeCFrame(hcf:ToObjectSpace(CFrame.new(hp+Vector3.new(math.random(),math.random(),math.random()))))
    end

    local hookOk = pcall(function()
        rawset(GunModule,"StartShooting",function(self2,...)
            local results={oldShoot(self2,...)}
            if not self2.ClientFighter or not self2.ClientFighter.IsLocalPlayer then return table.unpack(results) end
            local sd=results[3];if not sd or typeof(sd)~="table" then return table.unpack(results) end
            results[4]=true
            local tp=obj.__target
            if not obj.__active or not tp or not tp.Character then return table.unpack(results) end
            if not obj.__desync or obj.__curr~=tp then obj:__desync_start(tp);task.wait(0.1) end
            if obj.__task1 then task.cancel(obj.__task1);obj.__task1=nil end
            local head=tp.Character:FindFirstChild("Head")
            if not head then return table.unpack(results) end
            buildSD(sd,head)
            obj.__task1=task.delay(0.15,function() obj:__desync_stop() end)
            return table.unpack(results)
        end)
    end)

    if not hookOk then warn("[MagicBullet] Hook failed");return nil end

    if isAuto then
        obj.__conn1=Track(RunService.Heartbeat:Connect(function()
            if not obj.__active then return end
            obj.__target=findTarget()
        end))
    end

    function obj:Shutdown()
        self.__active=false
        if self.__conn1 then self.__conn1:Disconnect();self.__conn1=nil end
        if self.__conn2 then self.__conn2:Disconnect();self.__conn2=nil end
        if self.__task1 then task.cancel(self.__task1);self.__task1=nil end
        RunService:UnbindFromRenderStep("__mbRestore")
        pcall(function() rawset(GunModule,"StartShooting",self.__oldfunc) end)
    end

    getgenv().__MagicBullet=obj
    return obj
end

