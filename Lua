local _silentHooked=false;local _silentOldFunc=nil;local _silentCache=nil

local function SilentFetchEntities()
    local out={}
    for _,v in ipairs(Workspace:GetChildren()) do
        if v:FindFirstChildOfClass("Humanoid") then table.insert(out,v)
        elseif v.Name=="HurtEffect" then
            for _,c in ipairs(v:GetChildren()) do if c.ClassName~="Highlight" then table.insert(out,c) end end
        end
    end
    return out
end

local function SilentFindNearest()
    local center=GetScreenCenter();local best,bd=nil,math.huge
    local myRoot=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    for _,entity in ipairs(SilentFetchEntities()) do
        if entity==lp.Character then continue end
        local hum=entity:FindFirstChildOfClass("Humanoid");if not hum or hum.Health<=0 then continue end
        local hrp=entity:FindFirstChild("HumanoidRootPart");if not hrp then continue end
        if myRoot and (myRoot.Position-hrp.Position).Magnitude>SilentCfg.MaxDist then continue end
        local hp=entity:FindFirstChild(SilentCfg.Part) or entity:FindFirstChild("Head");if not hp then continue end
        local owner=Players:GetPlayerFromCharacter(entity)
        if owner and SilentCfg.TeamCheck and SameTeam(owner) then continue end
        if SilentCfg.VisCheck then local orig=myRoot and myRoot.Position or cam.CFrame.Position;if not IsVisible(orig,hp,SilentRayParams) then continue end end
        local sp,on=cam:WorldToViewportPoint(hp.Position);if not on then continue end
        local sd=(Vector2.new(sp.X,sp.Y)-center).Magnitude;if sd>SilentCfg.FOV then continue end
        if sd<bd then bd=sd;best=entity end
    end
    return best
end

local function SilentHook()
    if _silentHooked or not GunModule then return end
    local orig=GunModule.StartShooting;if not orig then return end
    _silentOldFunc=orig
    local ok=pcall(function()
        rawset(GunModule,"StartShooting",function(self2,...)
            local results={orig(self2,...)}
            if not self2.ClientFighter or not self2.ClientFighter.IsLocalPlayer then return table.unpack(results) end
            if not SilentCfg.Enabled or math.random(1,100)>SilentCfg.HitChance then return table.unpack(results) end
            local sd=results[3];if not sd or type(sd)~="table" then return table.unpack(results) end
            local entity=_silentCache;if not entity then return table.unpack(results) end
            local hp=entity:FindFirstChild(SilentCfg.Part) or entity:FindFirstChild("Head");if not hp then return table.unpack(results) end
            local tp=hp.Position
            if SilentCfg.Prediction>0 then pcall(function()
                local hrp=entity:FindFirstChild("HumanoidRootPart")
                if hrp then tp=tp+hrp.AssemblyLinearVelocity*(SilentCfg.Prediction*0.05) end
            end) end
            local myRoot=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            local sf=myRoot and myRoot.Position or cam.CFrame.Position
            pcall(function()
                if UtilityModule then
                    sd[utf8.char(0)]=UtilityModule:EncodeCFrame(CFrame.lookAt(sf,tp))
                    sd[utf8.char(1)]=UtilityModule:EncodeCFrame(CFrame.lookAt(tp,sf))
                    sd[utf8.char(2)]=hp
                    sd[utf8.char(3)]=UtilityModule:EncodeCFrame(hp.CFrame:ToObjectSpace(CFrame.new(tp+Vector3.new(math.random(-3,3)*0.01,math.random(-3,3)*0.01,math.random(-3,3)*0.01))))
                end
            end)
            return table.unpack(results)
        end)
    end)
    if ok and GunModule.StartShooting~=_silentOldFunc then _silentHooked=true else _silentOldFunc=nil end
end

local function SilentUnhook()
    if not _silentHooked or not GunModule then return end
    pcall(function() rawset(GunModule,"StartShooting",_silentOldFunc) end)
    _silentOldFunc=nil;_silentHooked=false
end

