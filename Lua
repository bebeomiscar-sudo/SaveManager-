local AimbotCfg = {
    Enabled=false,Part="Head",TeamCheck=true,VisCheck=true,
    FOV=150,DynamicFOV=false,Mode="Spring",
    SpringMass=5,SpringForce=50,SpringDamping=4,SpringSpeed=4,
    LingerTime=1.5,SoftSpeed=1.0,CurvePct=10,Prediction=0.08,ReactTime=0.1,
}

local aimbotSpring        = Spring.new(5,50,4,4)
local aimbotTarget        = nil
local aimbotReactTimer    = 0
local aimbotIsReacting    = false
local aimbotLingerTimer   = 0
local aimbotCurveProgress = 0
local aimbotCurveStart    = nil
local aimbotPrevPos       = nil
local aimbotPrevTick      = 0
local _aimbotCache        = nil
local _aimbotCacheTime    = 0
local CACHE_TTL           = 0.05

local AimbotFovCircle = Drawing.new("Circle")
AimbotFovCircle.Thickness=1.5;AimbotFovCircle.NumSides=64
AimbotFovCircle.Filled=false;AimbotFovCircle.Visible=false
AimbotFovCircle.Color=Color3.fromRGB(255,255,255);AimbotFovCircle.Radius=150

local function AimbotEffFOV()
    return AimbotCfg.DynamicFOV and AimbotCfg.FOV*(cam.FieldOfView/70) or AimbotCfg.FOV
end

local function AimbotFindTarget()
    local center=GetScreenCenter();local fov=AimbotEffFOV()
    local best,bd=nil,fov
    for _,p in ipairs(Players:GetPlayers()) do
        if not IsValidTarget(p) then continue end
        if AimbotCfg.TeamCheck and SameTeam(p) then continue end
        local part=GetBestPart(p.Character,AimbotCfg.Part);if not part then continue end
        local sp,on=cam:WorldToViewportPoint(part.Position);if not on then continue end
        local d=(Vector2.new(sp.X,sp.Y)-center).Magnitude
        if d<bd then
            if AimbotCfg.VisCheck and not IsVisible(cam.CFrame.Position,part,AimbotRayParams) then continue end
            bd=d;best=part
        end
    end
    return best
end

local function AimbotGetPredicted(part)
    local now=tick();local pos=part.Position
    if aimbotPrevPos and (now-aimbotPrevTick)>0 then
        local vel=(pos-aimbotPrevPos)/(now-aimbotPrevTick)
        local ping=0.05
        pcall(function() ping=Stats.Network.ServerStatsItem["Data Ping"]:GetValue()/1000 end)
        pos=pos+vel*(AimbotCfg.Prediction+ping)
    end
    aimbotPrevPos=part.Position;aimbotPrevTick=now
    return pos
end

local function AimbotApply(part,dt)
    if not CameraController then return end
    local aimPos=AimbotGetPredicted(part)
    local dir=(aimPos-cam.CFrame.Position).Unit
    local tRot=Vector2.new(math.asin(math.clamp(dir.Y,-1,1)),math.atan2(-dir.X,-dir.Z))
    local cur=CameraController.Rotation;local mode=AimbotCfg.Mode
    if mode=="Spring" then
        aimbotSpring.Target=Vector3.new(tRot.X,tRot.Y,0)
        local np=aimbotSpring:Update(dt)
        pcall(function() CameraController:ApplyRotationDelta(Vector2.new(np.X-cur.X,AngleDiff(cur.Y,np.Y))) end)
    elseif mode=="Soft" or mode=="Magnet" then
        local f=math.clamp(AimbotCfg.SoftSpeed*dt*6,0,1)
        local nx=cur.X+(tRot.X-cur.X)*f;local ny=cur.Y+AngleDiff(cur.Y,tRot.Y)*f
        pcall(function() CameraController:ApplyRotationDelta(Vector2.new(nx-cur.X,AngleDiff(cur.Y,ny))) end)
    elseif mode=="Curve" then
        local dist=math.sqrt((tRot.X-cur.X)^2+AngleDiff(cur.Y,tRot.Y)^2)
        if not aimbotCurveStart or dist>0.5 then aimbotCurveStart=cur;aimbotCurveProgress=0 end
        aimbotCurveProgress=math.clamp(aimbotCurveProgress+(AimbotCfg.CurvePct/100)*3*AimbotCfg.SoftSpeed*dt,0,1)
        local t=aimbotCurveProgress^2*(3-2*aimbotCurveProgress)
        local nx=aimbotCurveStart.X+(tRot.X-aimbotCurveStart.X)*t
        local ny=aimbotCurveStart.Y+AngleDiff(aimbotCurveStart.Y,tRot.Y)*t
        if aimbotCurveProgress>=1 then aimbotCurveStart=nil;aimbotCurveProgress=0 end
        pcall(function() CameraController:ApplyRotationDelta(Vector2.new(nx-cur.X,AngleDiff(cur.Y,ny))) end)
    elseif mode=="Linger" then
        aimbotLingerTimer+=dt
        if aimbotLingerTimer<AimbotCfg.LingerTime then
            pcall(function() CameraController:ApplyRotationDelta(Vector2.new(tRot.X-cur.X,AngleDiff(cur.Y,tRot.Y))) end)
        else aimbotTarget=nil;aimbotLingerTimer=0 end
    end
end

