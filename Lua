local _frameCount=0;local _frameTimer=tick();local _fps=0;local _aimbotCacheTime=0

Track(RunService.Heartbeat:Connect(function(dt)
    cam=Workspace.CurrentCamera
    _frameCount+=1;local now=tick()
    if now-_frameTimer>=1 then _fps=_frameCount;_frameTimer=now;_frameCount=0 end

    local cacheNow=tick()
    if cacheNow-_aimbotCacheTime>=CACHE_TTL then
        _aimbotCacheTime=cacheNow
        if AimbotCfg.Enabled then _aimbotCache=AimbotFindTarget() end
        if SilentCfg.Enabled then _silentCache=SilentFindNearest() end
    end

    if AimbotCfg.Enabled then
        if aimbotIsReacting then aimbotReactTimer-=dt;if aimbotReactTimer<=0 then aimbotIsReacting=false end end
        if not aimbotIsReacting then
            if aimbotTarget then
                local pc=aimbotTarget.Parent;local hum=pc and pc:FindFirstChildOfClass("Humanoid")
                local sv=true;if AimbotCfg.VisCheck then sv=IsVisible(cam.CFrame.Position,aimbotTarget,AimbotRayParams) end
                local inf=InFOV(aimbotTarget,AimbotEffFOV());local alive=hum and hum.Health>0
                if not alive or not inf or not sv then
                    aimbotTarget=nil;aimbotLingerTimer=0;aimbotCurveStart=nil;aimbotCurveProgress=0
                    aimbotSpring=Spring.new(AimbotCfg.SpringMass,AimbotCfg.SpringForce,AimbotCfg.SpringDamping,AimbotCfg.SpringSpeed)
                end
            end
            if not aimbotTarget and _aimbotCache then
                local cv=true;if AimbotCfg.VisCheck then cv=IsVisible(cam.CFrame.Position,_aimbotCache,AimbotRayParams) end
                if cv then aimbotTarget=_aimbotCache;aimbotIsReacting=true;aimbotReactTimer=AimbotCfg.ReactTime;aimbotPrevPos=nil;aimbotLingerTimer=0 end
            end
            if aimbotTarget and InFOV(aimbotTarget,AimbotEffFOV()) then AimbotApply(aimbotTarget,dt) end
        end
    end

    if RageCfg.Enabled and rageHudVisible then UpdateRageHUD() end
end))

Track(RunService.RenderStepped:Connect(function()
    cam=Workspace.CurrentCamera
    AimbotFovCircle.Position=GetScreenCenter();AimbotFovCircle.Radius=AimbotEffFOV();AimbotFovCircle.Visible=AimbotCfg.Enabled
    if SilentCfg.Enabled and SilentCfg.CircleOn then
        SilentCircle.Position=GetScreenCenter();SilentCircle.Radius=SilentCfg.FOV;SilentCircle.Visible=true
        SilentCircle.Color=_silentCache and SilentCfg.TargetColor or SilentCfg.CircleColor;SilentCircle.Thickness=SilentCfg.Thickness
    else SilentCircle.Visible=false end
    UpdateESP()
end))

