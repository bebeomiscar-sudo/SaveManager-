            local pm=obj:FindFirstAncestorOfClass("Model")
            if pm and pm:FindFirstChildOfClass("Humanoid") then return end
            pcall(function() obj.Material=Enum.Material.SmoothPlastic obj.CastShadow=false end)
        end
    end
    for _,obj in pairs(workspace:GetDescendants()) do pcall(nukeTextures,obj) end
    workspace.DescendantAdded:Connect(function(obj) pcall(nukeTextures,obj) end)
    local L = game:GetService("Lighting")
    for _,v in pairs(L:GetChildren()) do
        if v:IsA("BloomEffect") or v:IsA("SunRaysEffect") or v:IsA("DepthOfFieldEffect")
        or v:IsA("ColorCorrectionEffect") or v:IsA("BlurEffect") then pcall(function() v.Enabled=false end) end
