            while katanaCooldownEnabled do task.wait(3) pcall(setFastKatanaDeflect) end
        end)
        Notify({Title="Cloakware", Description="Remove Katana Cooldown ON", Time=3})
    else
        if katanaCooldownLoop then task.cancel(katanaCooldownLoop) katanaCooldownLoop=nil end
        Notify({Title="Cloakware", Description="Katana Cooldown restored", Time=3})
    end
end)

