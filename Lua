local function IsTeamMate(player)
    local LP = game:GetService("Players").LocalPlayer
    if not LP then return false end
    
    if LP.Team and player.Team then
        if LP.Team == player.Team then return true end
    end
    
    if LP.TeamColor and player.TeamColor then
        if LP.TeamColor == player.TeamColor then return true end
    end
    
    local lpChar = LP.Character
    local pChar = player.Character
    if lpChar and pChar then
        local lpTeam = lpChar:FindFirstChild("Team") or lpChar:FindFirstChild("team")
        local pTeam = pChar:FindFirstChild("Team") or pChar:FindFirstChild("team")
        if lpTeam and pTeam and lpTeam.Value == pTeam.Value then return true end
        
        local lpHead = lpChar:FindFirstChild("Head")
        local pHead = pChar:FindFirstChild("Head")
        if lpHead and pHead then
            if lpHead.BrickColor == pHead.BrickColor then return true end
        end
    end
    
    local lpTeamAttr = LP:GetAttribute("Team")
    local pTeamAttr = player:GetAttribute("Team")
    if lpTeamAttr and pTeamAttr and lpTeamAttr == pTeamAttr then return true end
    
    return false
end

-- ============================================================
-- WALL CHECK HELPER (FOR AIM)
-- ============================================================
local function IsWallBetween(pos1, pos2)
    local raycastParams = RaycastParams.new()
    raycastParams.FilterType = Enum.RaycastFilterType.Exclude
    local LP = game:GetService("Players").LocalPlayer
    if LP.Character then
        raycastParams.FilterDescendantsInstances = {LP.Character}
    end
    
    local direction = pos2 - pos1
    local raycastResult = workspace:Raycast(pos1, direction.Unit * direction.Magnitude, raycastParams)
    
    if raycastResult then
        local hitPart = raycastResult.Instance
        if hitPart and hitPart.CanCollide then
            local hitPlayer = game:GetService("Players"):GetPlayerFromCharacter(hitPart.Parent)
            if not hitPlayer or hitPlayer == LP then
                return true
            end
        end
    end
    
    return false
end

