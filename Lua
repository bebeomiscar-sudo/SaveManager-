local function SafeHttpGet(url)
    local tries = 3
    for i = 1, tries do
        local ok, result = pcall(function()
            return game:HttpGet(url)
        end)
        if ok and type(result) == "string" and #result > 100 then
            return result
        end
        warn(("[Loader] Attempt %d/%d failed for: %s"):format(i, tries, url))
        task.wait(1 * i)
    end
    return nil
end

local function SafeLoadstring(source, chunkName)
    -- Try loadstring first
    local ok1, chunk = pcall(loadstring, source, chunkName or "chunk")
    if ok1 and type(chunk) == "function" then
        local ok2, result = pcall(chunk)
        if ok2 then return result end
        warn("[Loader] Execution error in " .. (chunkName or "chunk") .. ": " .. tostring(result))
        return nil
    end
    -- Fallback without chunk name
    local ok3, chunk2 = pcall(loadstring, source)
    if ok3 and type(chunk2) == "function" then
        local ok4, result2 = pcall(chunk2)
        if ok4 then return result2 end
        warn("[Loader] Execution error (fallback): " .. tostring(result2))
        return nil
    end
    warn("[Loader] loadstring failed: " .. tostring(chunk))
    return nil
end

