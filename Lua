function SaveManager:ApplyTheme(ThemeName)
    local theme = self.Themes[ThemeName]
    if not theme or not self.Library then return end

    local Lib = self.Library
    for k, v in next, theme do
        Lib[k] = v
    end
    Lib.AccentColorDark = Lib:GetDarkerColor(Lib.AccentColor)
    Lib:UpdateColorsUsingRegistry()

    self.CurrentTheme = ThemeName
end

function SaveManager:BuildThemeSection(Tab)
    assert(Tab,         'BuildThemeSection: Tab is required.')
    assert(self.Library,'BuildThemeSection: Call SetLibrary first.')

    local Box = Tab:AddLeftGroupbox('Theme')

    local themeNames = {}
    for name in next, self.Themes do table.insert(themeNames, name) end
    table.sort(themeNames)

    Box:AddDropdown('SaveManager_Theme', {
        Text     = 'Select theme';
        Values   = themeNames;
        Default  = themeNames[1];
        AllowNull = false;
        Callback = function(val)
            if val then self:ApplyTheme(val) end
        end;
    })

    -- Custom accent color picker
    Box:AddLabel('Accent color'):AddColorPicker('SaveManager_AccentColor', {
        Default  = self.Library.AccentColor;
        Title    = 'Accent color';
        Callback = function(color)
            if self.Library then
                self.Library.AccentColor     = color
                self.Library.AccentColorDark = self.Library:GetDarkerColor(color)
                self.Library:UpdateColorsUsingRegistry()
            end
        end;
    })
end

return SaveManager
