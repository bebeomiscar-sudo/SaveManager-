local function spoofPlayerName(player)
    local Config = getgenv().NameSpooferConfig
    if not Config.name_spoof then return end
    if player == lp then
        pcall(function()
            player.Name        = Config.your_spoofed_name
            player.DisplayName = Config.your_spoofed_name
        end)
    else
        pcall(function()
            player.Name        = Config.spoofed_enemy_names
            player.DisplayName = Config.spoofed_enemy_names
        end)
    end
end

local GUI_PATH = {
    "PlayerGui","MainGui","PlayerList","Container",
    "Elements","Container","Middle","List","Container"
}

local function getListContainer()
    local node = lp
    for _, name in ipairs(GUI_PATH) do
        if not node then return nil end
        node = node:FindFirstChild(name)
    end
    return node
end

local function findAllTitleLabels(instance, results)
    results = results or {}
    if not instance then return results end
    for _, child in ipairs(instance:GetChildren()) do
        if child:IsA("TextLabel") and child.Name == "Title" then
            table.insert(results, child)
        end
        findAllTitleLabels(child, results)
    end
    return results
end

local function spoofTitleLabelsInContainer(container)
    if not container then return end
    local Config = getgenv().NameSpooferConfig
    for _, playerFrame in ipairs(container:GetChildren()) do
        if not playerFrame:IsA("Frame") then continue end
        local spoofed = false
        local inner   = playerFrame:FindFirstChild("Container")
        if inner and inner:IsA("Frame") then
            for _, child in ipairs(inner:GetChildren()) do
                if child:IsA("Frame") then
                    local lbl = child:FindFirstChild("Title")
                    if lbl and lbl:IsA("TextLabel") then
                        local isLocal = lbl.Text==lp.Name or lbl.Text==lp.DisplayName
                        lbl.Text = isLocal and Config.your_spoofed_name or Config.spoofed_enemy_names
                        spoofed  = true
                    end
                end
            end
        end
        if not spoofed then
            local labels = findAllTitleLabels(playerFrame)
            for _, lbl in ipairs(labels) do
                local isLocal = lbl.Text==lp.Name or lbl.Text==lp.DisplayName
                lbl.Text = isLocal and Config.your_spoofed_name or Config.spoofed_enemy_names
            end
        end
    end
end

local function startNameSpoofer()
    if nameSpooferRunning then return end
    nameSpooferRunning = true
    local conns = {}

    -- Spoof current players
    for _, p in ipairs(Players:GetPlayers()) do spoofPlayerName(p) end

    -- Watch new players
    local paConn = Track(Players.PlayerAdded:Connect(spoofPlayerName))
    table.insert(conns, paConn)

    -- GUI loop
    task.spawn(function()
        local playerGui = lp:WaitForChild("PlayerGui", 30)
        if not playerGui then return end
        local monitored = nil

        while task.wait(0.5) do
            if not nameSpooferRunning then break end
            local cfg = getgenv().NameSpooferConfig
            if not cfg.name_spoof then continue end

            local listContainer = getListContainer()
            if listContainer and listContainer ~= monitored then
                monitored = listContainer
                local watchConn = Track(listContainer.ChildAdded:Connect(function(child)
                    if child:IsA("Frame") then
                        task.wait(0.1)
                        pcall(spoofTitleLabelsInContainer, listContainer)
                    end
                end))
                table.insert(conns, watchConn)
            end
            if listContainer then
                pcall(spoofTitleLabelsInContainer, listContainer)
            end
        end
    end)

    nameSpooferConnections = conns
end

local function stopNameSpoofer()
    nameSpooferRunning = false
    for _, c in ipairs(nameSpooferConnections) do
        pcall(function() c:Disconnect() end)
    end
    nameSpooferConnections = {}
end

