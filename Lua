sec_display:CreateToggle("Dark Textures", false, function(value)
    if not value then Notify({Title="Cloakware",Description="Rejoin to restore textures",Time=4}) return end
    local function isMapPart(p)
        if not p:IsA("BasePart") then return false end
        if p:FindFirstAncestorOfClass("Tool") then return false end
        local pm = p:FindFirstAncestorOfClass("Model")
        if pm and pm:FindFirstChildOfClass("Humanoid") then return false end
        if p:FindFirstChildWhichIsA("SpecialMesh") or p:FindFirstChildWhichIsA("MeshPart") then return false end
        if p.Size.Magnitude < 5 then return false end
        if p.Material == Enum.Material.Grass or p.Name:lower():find("tree") then return false end
        if not p.Anchored then return false end return true
    end
    local function applyCharcoal()
        for _,p in pairs(workspace:GetDescendants()) do
            if isMapPart(p) then p.Color=Color3.fromRGB(50,50,50) p.Material=Enum.Material.SmoothPlastic end
        end
    end
    applyCharcoal()
