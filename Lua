local MagicBulletObj = nil

local function BuildMagicBulletObj(isAuto)
    if getgenv().__MagicBullet then
        getgenv().__MagicBullet:Shutdown()
        getgenv().__MagicBullet = nil
    end

    local GunMod  = GunModule
    local UtilMod = UtilityModule
    if not GunMod or not UtilMod then
        warn("[MagicBullet] Missing modules")
        return nil
    end

    local oldShoot = GunMod.StartShooting
    if not oldShoot then
        warn("[MagicBullet] StartShooting not found")
        return nil
    end

    local obj = {
        __active  = true,
        __target  = nil,
        __desync  = false,
        __curr    = nil,
        __conn1   = nil,
        __conn2   = nil,
        __task1   = nil,
        __oldfunc = oldShoot,
    }

    local function findTarget()
        local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
        if not myRoot then return nil end
        local best, bestDist = nil, math.huge
        for _, player in next, Players:GetPlayers() do
            if player == lp then continue end
            if SameTeam(player) then continue end
            local char = player.Character
            if not char then continue end
            local root = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            local hum  = char:FindFirstChildWhichIsA("Humanoid")
            if not (root and head and hum and hum.Health > 0) then continue end
            local dist = (myRoot.Position - root.Position).Magnitude
            if dist > 200 then continue end
            if dist < bestDist then bestDist=dist;best=player end
        end
        return best
    end

    function obj:__desync_start(targetPlayer)
        if self.__conn2 then self.__conn2:Disconnect() end
        self.__desync = true
        self.__curr   = targetPlayer

        self.__conn2 = Track(RunService.Heartbeat:Connect(function()
            if not self.__desync then return end
            local myRoot = lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
            if not myRoot then return end
            local tChar = targetPlayer.Character
            local tHRP  = tChar and tChar:FindFirstChild("HumanoidRootPart")
            if not tHRP then self:__desync_stop();return end

            local savedCF   = myRoot.CFrame
            local savedVel  = myRoot.AssemblyLinearVelocity
            local savedRVel = myRoot.AssemblyAngularVelocity

            myRoot.CFrame = tHRP.CFrame * CFrame.new(0, -5, 0)

            RunService:BindToRenderStep("__mbRestore", 101, function()
                pcall(function()
                    myRoot.CFrame = savedCF
                    myRoot.AssemblyLinearVelocity  = savedVel
                    myRoot.AssemblyAngularVelocity = savedRVel
                end)
                RunService:UnbindFromRenderStep("__mbRestore")
            end)
        end))
    end

    function obj:__desync_stop()
        self.__desync = false
        self.__curr   = nil
        if self.__conn2 then self.__conn2:Disconnect();self.__conn2=nil end
        RunService:UnbindFromRenderStep("__mbRestore")
    end

    local function buildShotData(sd, targetHead)
        local headPos  = targetHead.Position
        local headCF   = targetHead.CFrame
        local shootPos = headPos - Vector3.new(0, 5, 0)
        local aimCF    = CFrame.lookAt(shootPos, headPos)
        sd[utf8.char(0)] = UtilMod:EncodeCFrame(
            CFrame.new(shootPos, headPos) * CFrame.Angles(aimCF:ToOrientation())
        )
        sd[utf8.char(1)] = UtilMod:EncodeCFrame(
            CFrame.new(headPos) * CFrame.Angles(aimCF:ToOrientation())
        )
        sd[utf8.char(2)] = targetHead
        sd[utf8.char(3)] = UtilMod:EncodeCFrame(
            headCF:ToObjectSpace(CFrame.new(
                headPos + Vector3.new(math.random(),math.random(),math.random())
            ))
        )
    end

    local hookOk = pcall(function()
        rawset(GunMod, "StartShooting", function(self2, ...)
            local results = {oldShoot(self2, ...)}
            if not self2.ClientFighter or not self2.ClientFighter.IsLocalPlayer then
                return table.unpack(results)
            end
            local sd = results[3]
            if not sd or typeof(sd) ~= "table" then return table.unpack(results) end
            results[4] = true

            local targetPlayer = obj.__target
            if not obj.__active or not targetPlayer or not targetPlayer.Character then
                return table.unpack(results)
            end

            if not obj.__desync or obj.__curr ~= targetPlayer then
                obj:__desync_start(targetPlayer)
                task.wait(0.1)
            end

            if obj.__task1 then task.cancel(obj.__task1);obj.__task1=nil end

            local targetHead = targetPlayer.Character:FindFirstChild("Head")
            if not targetHead then return table.unpack(results) end

            buildShotData(sd, targetHead)

            obj.__task1 = task.delay(0.15, function() obj:__desync_stop() end)
            return table.unpack(results)
        end)
    end)

    if not hookOk then
        warn("[MagicBullet] Hook failed")
        return nil
    end

    if isAuto then
        obj.__conn1 = Track(RunService.Heartbeat:Connect(function()
            if not obj.__active then return end
            obj.__target = findTarget()
        end))
    end

    function obj:Shutdown()
        self.__active = false
        if self.__conn1 then self.__conn1:Disconnect();self.__conn1=nil end
        if self.__conn2 then self.__conn2:Disconnect();self.__conn2=nil end
        if self.__task1 then task.cancel(self.__task1);self.__task1=nil end
        RunService:UnbindFromRenderStep("__mbRestore")
        pcall(function() rawset(GunMod, "StartShooting", self.__oldfunc) end)
    end

    getgenv().__MagicBullet = obj
    return obj
end

