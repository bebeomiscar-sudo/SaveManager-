local katanaCooldownEnabled = false
local katanaCooldownLoop = nil

local function setFastKatanaDeflect()
    task.wait(0.01)
    for _, v in pairs(getgc(true)) do
        if type(v) == "table" then
            if rawget(v, "DeflectCooldown") then rawset(v, "DeflectCooldown", 0.01) end
            if rawget(v, "DeflectDuration") then rawset(v, "DeflectDuration", 0.01) end
        end
    end
    task.wait(0.01)
    pcall(function()
        local RS = game:GetService("ReplicatedStorage")
        local Modules = RS:FindFirstChild("Modules")
        if Modules then
            local lib = Modules:FindFirstChild("ItemLibrary") or Modules:FindFirstChild("ItemLibrary", true)
            if lib then
                local IL = require(lib)
                if IL and IL.Items then
                    for _, item in pairs(IL.Items) do
                        if item.Name and string.find(item.Name:lower(), "katana") then
                            item.DeflectCooldown = 0.01
                            item.DeflectDuration = 0.01
                        end
                    end
                end
            end
        end
    end)
    task.wait(0.01)
    pcall(function()
        local LP = game:GetService("Players").LocalPlayer
        local MeleeModule = require(LP.PlayerScripts.Modules.ItemTypes.Melee)
        local oldNew = MeleeModule.new
        MeleeModule.new = function(...)
            local self = oldNew(...)
            if self and self.Info and self.Info.Name and string.find(self.Info.Name:lower(), "katana") then
                self.Info.DeflectCooldown = 0.01
                self.Info.DeflectDuration = 0.8
            end
            return self
        end
    end)
end

