    local found=false
    if ItemLibrary then local items=ItemLibrary.Items or ItemLibrary.Weapons;if type(items)=="table" then for n,item in pairs(items) do if type(item)=="table" and tostring(item.Name or n):lower():find("katana") then for _,f in ipairs(COOLDOWN_FIELDS) do if item[f]~=nil then pcall(function() rawset(item,f,0) end);found=true end end end end end end
