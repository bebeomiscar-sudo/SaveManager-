end)
sec_display:CreateToggle("Remove Textures (Potato FPS)", false, function(value)
    if not value then Notify({Title="Cloakware",Description="Rejoin to restore textures",Time=4}) return end
    local player = game:GetService("Players").LocalPlayer
    local function isWeaponDescendant(obj)
        if obj:FindFirstAncestorOfClass("Tool") then return true end
        local char = player.Character
        if char and obj:IsDescendantOf(char) then return true end return false
    end
    local function nukeTextures(obj)
        if isWeaponDescendant(obj) then return end
        if obj:IsA("Texture") or obj:IsA("Decal") or obj:IsA("SpecialMesh") then pcall(function() obj.Transparency=1 end) end
        if obj:IsA("BasePart") then
