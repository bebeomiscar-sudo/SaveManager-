    FOVTransparency = 20,
    TeamCheck = true,
    WallCheck = true,
    AimParts = {"Head", "UpperTorso", "HumanoidRootPart"},
    AimOffset = Vector3.new(0, 0, 0),
    CycleInterval = 0.6,
}

local AIM_PARTS_LIST = {
    "Head","UpperTorso","HumanoidRootPart","LowerTorso","Torso","LeftUpperArm","RightUpperArm",
    "LeftLowerArm","RightLowerArm","LeftHand","RightHand","LeftUpperLeg","RightUpperLeg",
    "LeftLowerLeg","RightLowerLeg","LeftFoot","RightFoot","LeftArm","RightArm","LeftLeg","RightLeg",
}
local aimPartsSelected = {Head = true, UpperTorso = true, HumanoidRootPart = true}

local function rebuildAimParts()
    AimConfig.AimParts = {}
    for _, name in ipairs(AIM_PARTS_LIST) do if aimPartsSelected[name] then table.insert(AimConfig.AimParts, name) end end
    if #AimConfig.AimParts == 0 then AimConfig.AimParts = {"HumanoidRootPart"} end
end

local aimRunning = false
local aimLocked = false
