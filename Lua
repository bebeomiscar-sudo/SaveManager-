local function setCircleColor(state)
    if not aimFovStroke then return end
    if state == "locked" then aimFovStroke.Color = Color3.fromRGB(0, 255, 80)
    elseif state == "search" then aimFovStroke.Color = Color3.fromRGB(255, 165, 0)
    else aimFovStroke.Color = AimConfig.FOVColor end
end

local function buildFovCircle()
    local LP = Players.LocalPlayer
    if aimFovGui then aimFovGui:Destroy() aimFovGui=nil aimFovStroke=nil aimFovCircle=nil end
    if not AimConfig.ShowFOVCircle then return end
    local sg = Instance.new("ScreenGui")
    sg.Name="CloakAimFOV" sg.ResetOnSpawn=false sg.IgnoreGuiInset=true sg.Parent = LP:WaitForChild("PlayerGui")
    aimFovGui = sg
    local f = Instance.new("Frame")
    f.AnchorPoint=Vector2.new(0.5,0.5) f.Position=UDim2.new(0.5,0,0.5,0)
    f.Size=UDim2.new(0,AimConfig.FOVRadius*2,0,AimConfig.FOVRadius*2)
    f.BackgroundTransparency=1 f.BorderSizePixel=0 f.Parent=sg
    aimFovCircle = f
    local corner = Instance.new("UICorner") corner.CornerRadius=UDim.new(1,0) corner.Parent=f
    local stroke = Instance.new("UIStroke")
    stroke.Color=AimConfig.FOVColor stroke.Thickness=AimConfig.FOVThickness stroke.Transparency=AimConfig.FOVTransparency/100 stroke.Parent=f
    aimFovStroke = stroke
end

local function removeFovCircle()
    if aimFovGui then aimFovGui:Destroy() aimFovGui=nil aimFovStroke=nil aimFovCircle=nil end
end

local function updateFovSize()
    if aimFovCircle then aimFovCircle.Size = UDim2.new(0,AimConfig.FOVRadius*2,0,AimConfig.FOVRadius*2) end
end

local function getAimPos(char)
    local parts = AimConfig.AimParts
    if #parts == 0 then return nil end
    local idx = ((aimPartCycleIdx - 1) % #parts) + 1
    for i = 0, #parts - 1 do
        local name = parts[((idx - 1 + i) % #parts) + 1]
        local p = char:FindFirstChild(name)
        if p and p:IsA("BasePart") then return p.Position + AimConfig.AimOffset end
    end
    for _, p in pairs(char:GetChildren()) do
        if p:IsA("BasePart") and p.Name ~= "HumanoidRootPart" then return p.Position + AimConfig.AimOffset end
    end
    return nil
end

local function isInFovAim(worldPos)
    local Camera = workspace.CurrentCamera
    local sp, onScreen = Camera:WorldToScreenPoint(worldPos)
    if not onScreen then return false end
    local center = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
    return (Vector2.new(sp.X,sp.Y) - center).Magnitude <= AimConfig.FOVRadius
end

local function findBestAimTarget()
    local LP = Players.LocalPlayer
    local selfChar = LP.Character
    local selfRoot = selfChar and selfChar:FindFirstChild("HumanoidRootPart")
    if not selfRoot then return nil end
    local best, bestDist = nil, math.huge
    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LP and player.Character then
            if AimConfig.TeamCheck and IsTeamMate(player) then continue end
            local char = player.Character
            local hum = char:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local root = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChildWhichIsA("BasePart")
                if root then
                    local worldDist = (root.Position - selfRoot.Position).Magnitude
                    if worldDist <= AimConfig.LockDistance then
                        local aimPos = getAimPos(char)
                        if aimPos then
                            if not isInFovAim(aimPos) then continue end
                            if AimConfig.WallCheck and IsWallBetween(selfRoot.Position, aimPos) then continue end
                            if worldDist < bestDist then bestDist = worldDist best = player end
                        end
                    end
                end
            end
        end
    end
    return best
end

-- THIS ROTATES THE CAMERA (AND GUN IN FIRST PERSON) TOWARD TARGET
local function aimCameraAtPosition(targetPos)
    local Camera = workspace.CurrentCamera
    if not Camera then return end
    
    local camPos = Camera.CFrame.Position
    local direction = (targetPos - camPos).Unit
    local targetCF = CFrame.lookAt(camPos, camPos + direction)
    
    local dt = math.min(RunService.RenderStepped:Wait() or 0.016, 0.1)
    local alpha = math.clamp(1 - (1 - AimConfig.SmoothFactor/100)^(dt * 60), 0.01, 1)
    
    Camera.CFrame = Camera.CFrame:Lerp(targetCF, alpha)
    
    -- Also rotate character body
    local LP = Players.LocalPlayer
    local char = LP.Character
    if char then
        local humanoid = char:FindFirstChildOfClass("Humanoid")
        local rootPart = char:FindFirstChild("HumanoidRootPart")
        if humanoid and rootPart then
            local flatDir = Vector3.new(direction.X, 0, direction.Z)
            if flatDir.Magnitude > 0.1 then
                humanoid.AutoRotate = false
                rootPart.CFrame = CFrame.lookAt(rootPart.Position, rootPart.Position + flatDir.Unit)
            end
        end
    end
end

local function stopAim()
    aimRunning=false aimLocked=false aimTarget=nil aimPartCycleIdx=1 aimPartCycleTimer=0
    if aimRenderConn then aimRenderConn:Disconnect() aimRenderConn=nil end
    if aimInputConn then aimInputConn:Disconnect() aimInputConn=nil end
    removeFovCircle()
end

local function startAim()
    aimRunning=true aimPartCycleIdx=1 aimPartCycleTimer=0
    local UIS = UserInputService
    
    isMobileDevice = (UIS.TouchEnabled and not UIS.KeyboardEnabled)
    
    buildFovCircle()
    aimLocked = isMobileDevice
    setCircleColor(aimLocked and "search" or "idle")
    
    if not isMobileDevice then
        aimInputConn = UIS.InputBegan:Connect(function(input, processed)
            if processed then return end
            if input.KeyCode == AimConfig.ToggleKey then
                aimLocked = not aimLocked
                if not aimLocked then aimTarget=nil end
                setCircleColor(aimLocked and "search" or "idle")
            end
        end)
    end
    
    aimRenderConn = RunService.RenderStepped:Connect(function(dt)
        if not aimRunning or not aimLocked then return end
        
        aimTarget = findBestAimTarget()
        setCircleColor(aimTarget and "locked" or "search")
        
        if not aimTarget then return end
        
        local char = aimTarget.Character
        if not char then return end
        
        if #AimConfig.AimParts > 1 then
            aimPartCycleTimer = aimPartCycleTimer + dt
            if aimPartCycleTimer >= AimConfig.CycleInterval then 
                aimPartCycleTimer = 0 
                aimPartCycleIdx = (aimPartCycleIdx % #AimConfig.AimParts) + 1 
            end
        end
        
        local aimPos = getAimPos(char)
        if not aimPos then return end
        
        -- Rotate camera (and gun in first person) toward target
        aimCameraAtPosition(aimPos)
    end)
end

