-- ── Prediction — leads target based on velocity ────────────
local _prevPredPos  = {}
local _prevPredTick = {}

local function Predict(hitPart, shootPos)
    local pos = hitPart.Position
    local now = tick()
    local pid = tostring(hitPart)

    if _prevPredPos[pid] and (now - _prevPredTick[pid]) > 0 then
        local vel = (pos - _prevPredPos[pid]) / (now - _prevPredTick[pid])

        -- Add ping compensation
        local ping = 0.05
        pcall(function()
            ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue() / 1000
        end)

        local predFactor = RageCfg.PredictionFactor + ping
        pos = pos + vel * predFactor
    end

    _prevPredPos[pid]  = hitPart.Position
    _prevPredTick[pid] = now
    return pos
end

-- ── Ragebot target finder ──────────────────────────────────
local function RageGetTarget()
    local myChar = lp.Character
    local myHRP  = myChar and myChar:FindFirstChild("HumanoidRootPart")
    if not myHRP then return nil end

    -- Priority player
    if RageCfg.PriorityPlayer ~= "None" then
        for _, p in ipairs(Players:GetPlayers()) do
            if p.Name == RageCfg.PriorityPlayer
            or p.DisplayName == RageCfg.PriorityPlayer then
                if not IsValidTarget(p) then break end
                if RageCfg.TeamCheck and SameTeam(p) then break end
                return p.Character
            end
        end
    end

    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if not IsValidTarget(p) then continue end
        if RageCfg.TeamCheck and SameTeam(p) then continue end
        local char = p.Character
        local hrp  = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        local dist = (myHRP.Position - hrp.Position).Magnitude
        if dist > RageCfg.MaxDist then continue end
        if RageCfg.VisCheck and not IsVisible(cam.CFrame.Position, hrp, RagebotRayParams) then continue end
        if dist < bestDist then
            bestDist = dist
            best     = char
        end
    end
    return best
end

