local AimConfig = {
    Enabled = false,
    ToggleKey = Enum.KeyCode.L,
    LockDistance = 500,
    SmoothFactor = 15,
    FOVRadius = 120,
    ShowFOVCircle = true,
    FOVColor = Color3.fromRGB(255, 50, 50),
