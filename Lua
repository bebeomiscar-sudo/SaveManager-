local AimbotRayParams   = RaycastParams.new()
AimbotRayParams.FilterType   = Enum.RaycastFilterType.Exclude
local SilentRayParams   = RaycastParams.new()
SilentRayParams.FilterType   = Enum.RaycastFilterType.Exclude
local RagebotRayParams  = RaycastParams.new()
