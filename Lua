task.spawn(function()
    local Players           = game:GetService("Players")
    local ReplicatedStorage = game:GetService("ReplicatedStorage")
    local player            = Players.LocalPlayer
    local playerScripts     = player.PlayerScripts
    local controllers       = playerScripts:WaitForChild("Controllers", 15)

    local EnumLibrary     = require(ReplicatedStorage.Modules:WaitForChild("EnumLibrary", 10))
    if EnumLibrary then pcall(function() EnumLibrary:WaitForEnumBuilder() end) end
    local CosmeticLibrary = require(ReplicatedStorage.Modules:WaitForChild("CosmeticLibrary", 10))
    local ItemLibrary     = require(ReplicatedStorage.Modules:WaitForChild("ItemLibrary", 10))
    local DataController  = require(controllers:WaitForChild("PlayerDataController", 10))

    if not CosmeticLibrary or not DataController then
        Notify({Title="Cloakware", Description="Failed — wrong game?", Time=5}) return
    end

    local EmotesFolder = ReplicatedStorage:WaitForChild("Modules"):WaitForChild("Emotes", 10)
    if EmotesFolder then
        for _,child in pairs(EmotesFolder:GetChildren()) do
            if child:IsA("ModuleScript") then
                _emoteModules[child.Name] = child
                table.insert(_allEmoteNames, child.Name)
            end
        end
        table.sort(_allEmoteNames, function(a,b)
            if a=="None" then return true end if b=="None" then return false end return a<b
        end)
        if not getgenv()._CloakEmoteHookInstalled then
            getgenv()._CloakEmoteHookInstalled = true
            local oldRequire
            oldRequire = hookfunction(require, newcclosure(function(module)
                if typeof(module)=="Instance" and module:IsA("ModuleScript")
                    and module.Parent==EmotesFolder then
                    local swapTarget = _emoteSwaps[module.Name]
                    if swapTarget and _emoteModules[swapTarget] then
                        return oldRequire(_emoteModules[swapTarget])
                    end
                end
                return oldRequire(module)
            end))
        end
    end

    local equipped = {} local favorites = {} local constructingWeapon = nil
    local viewingProfile = nil local lastUsedWeapon = nil

    local CONFIG_FOLDER = "Cloakware"
    local CONFIG_FILE   = CONFIG_FOLDER.."/equipped_config.json"
    local function ensureFolder()
        if not isfolder(CONFIG_FOLDER) then makefolder(CONFIG_FOLDER) end
    end
    local function saveEquippedConfig(eq)
        pcall(function()
            ensureFolder()
            local out = {}
            for wKey, slots2 in pairs(eq) do
                out[tostring(wKey)] = {}
                for slotName, cd in pairs(slots2) do
                    if not tostring(slotName):find("^__multi_") then
                        out[tostring(wKey)][tostring(slotName)] = tostring(cd.Name or "")
                    end
                end
            end
            writefile(CONFIG_FILE, game:GetService("HttpService"):JSONEncode(out))
        end)
    end
    local function loadEquippedConfig()
        local data = {}
        pcall(function()
            if isfile(CONFIG_FILE) then
                data = game:GetService("HttpService"):JSONDecode(readfile(CONFIG_FILE))
            end
        end)
        return data
    end

    local function cloneCosmetic(name, cosmeticType, options)
        local base = CosmeticLibrary.Cosmetics[name]
        if not base then return nil end
        local data = {} for k,v in pairs(base) do data[k]=v end
        data.Name=name data.Type=data.Type or cosmeticType data.Seed=data.Seed or math.random(1,1000000)
        if EnumLibrary then
            local ok,enumId=pcall(EnumLibrary.ToEnum,EnumLibrary,name)
            if ok and enumId then data.Enum=enumId data.ObjectID=data.ObjectID or enumId end
        end
        if options then
            if options.inverted~=nil then data.Inverted=options.inverted end
            if options.favoritesOnly~=nil then data.OnlyUseFavorites=options.favoritesOnly end
        end
        return data
    end

    local origOwnsNormally    = CosmeticLibrary.OwnsCosmeticNormally
    local origOwnsUniversally = CosmeticLibrary.OwnsCosmeticUniversally
    local origOwnsForWeapon   = CosmeticLibrary.OwnsCosmeticForWeapon
    local origOwnsCosmetic    = CosmeticLibrary.OwnsCosmetic
    local origGet             = DataController.Get
    local origGetWeaponData   = DataController.GetWeaponData

    DataController.GetWeaponData = function(self, weaponName)
        local data = origGetWeaponData(self, weaponName)
        if not data then return nil end
        local merged = {} for k,v in pairs(data) do merged[k]=v end merged.Name=weaponName
        if equipped[weaponName] then
            for ct,cd in pairs(equipped[weaponName]) do
                if not tostring(ct):find("^__multi_") then merged[ct]=cd end
            end
        end
        return merged
    end

    local function makeUnlockProxy(data)
        local proxy = {}
        if type(data)=="table" then for k,v in pairs(data) do proxy[k]=v end end
        return setmetatable(proxy, {__index=function(_,k)
            if type(k)=="string" and k~="" then return true end return nil
        end})
    end

    local function buildGetFn(unlockCosmetics, unlockEmotes)
        return function(self, key)
            local data   = origGet(self, key)
            local keyStr = tostring(key):lower()
            if unlockCosmetics and keyStr=="cosmeticinventory" then return makeUnlockProxy(data) end
            if unlockEmotes and (keyStr:find("emote") and keyStr:find("inventor")) then return makeUnlockProxy(data) end
            if unlockEmotes and (keyStr=="ownedemotes" or keyStr=="emotes") then return makeUnlockProxy(data) end
            if key=="FavoritedCosmetics" then
                local result = data and table.clone(data) or {}
                for w,favs in pairs(favorites) do
                    result[w]=result[w] or {}
                    for n,v in pairs(favs) do result[w][n]=v end
                end
                return result
            end
            return data
        end
    end

    local function refreshDataGet()
        DataController.Get = buildGetFn(unlockAllEnabled, unlockAllEmotesEnabled)
    end
    DataController.Get = buildGetFn(false, false)

    local prevUnlockAll       = false
    local prevUnlockAllEmotes = false
    game:GetService("RunService").Heartbeat:Connect(function()
        if unlockAllEnabled ~= prevUnlockAll then
            prevUnlockAll = unlockAllEnabled
            if unlockAllEnabled then
                CosmeticLibrary.OwnsCosmeticNormally    = function() return true end
                CosmeticLibrary.OwnsCosmeticUniversally = function() return true end
                CosmeticLibrary.OwnsCosmeticForWeapon   = function() return true end
                CosmeticLibrary.OwnsCosmetic = function(self, inv, name, weapon)
                    if name and tostring(name):find("MISSING_") then
                        return pcall(origOwnsCosmetic,self,inv,name,weapon) and origOwnsCosmetic(self,inv,name,weapon)
                    end
                    return true
                end
                Notify({Title="Cloakware",Description="Unlock All ON",Time=3})
            else
                CosmeticLibrary.OwnsCosmeticNormally    = origOwnsNormally
                CosmeticLibrary.OwnsCosmeticUniversally = origOwnsUniversally
                CosmeticLibrary.OwnsCosmeticForWeapon   = origOwnsForWeapon
                CosmeticLibrary.OwnsCosmetic            = origOwnsCosmetic
                Notify({Title="Cloakware",Description="Unlock All OFF",Time=3})
            end
            refreshDataGet()
            task.defer(function() saveEquippedConfig(equipped) end)
        end
        if unlockAllEmotesEnabled ~= prevUnlockAllEmotes then
            prevUnlockAllEmotes = unlockAllEmotesEnabled
            refreshDataGet()
        end
    end)

    local allWeapons = {} local weaponKeyMap = {}
    local function resolveWeaponName(key)
        if type(key)=="string" and not key:match("^%d+$") then return key end
        if EnumLibrary then
            local ok,name=pcall(function() return EnumLibrary:FromEnum(key) end)
            if ok and name and type(name)=="string" and not name:match("^%d+$") then return name end
        end
        if ItemLibrary and ItemLibrary.Items then
            for itemName,itemData in pairs(ItemLibrary.Items) do
                if type(itemName)=="string" and not itemName:match("^%d+$") then
                    if tostring(itemData and itemData.ObjectID or "")==tostring(key) then return itemName end
                    if EnumLibrary then
                        local ok2,eid=pcall(function() return EnumLibrary:ToEnum(itemName) end)
                        if ok2 and tostring(eid)==tostring(key) then return itemName end
                    end
                end
            end
        end
        return nil
    end

    if CosmeticLibrary.Cosmetics then
        local seen = {}
        for _,cd in pairs(CosmeticLibrary.Cosmetics) do
            local rawKey = cd.WeaponType or cd.Weapon or cd.ForWeapon or cd.ItemType or cd.AppliesTo
            if rawKey then
                local name = resolveWeaponName(rawKey)
                if name and not seen[name] then seen[name]=true weaponKeyMap[name]=rawKey table.insert(allWeapons,name) end
            end
        end
    end
    if ItemLibrary and ItemLibrary.Items then
        for itemName,_ in pairs(ItemLibrary.Items) do
            if type(itemName)=="string" and not itemName:match("^%d+$") and not weaponKeyMap[itemName] then
                weaponKeyMap[itemName]=itemName table.insert(allWeapons,itemName)
            end
        end
    end
    pcall(function()
        local inv = origGet(DataController,"WeaponInventory")
        if type(inv)=="table" then
            for key,_ in pairs(inv) do
                local name=resolveWeaponName(key)
                if name and not weaponKeyMap[name] then weaponKeyMap[name]=key table.insert(allWeapons,name) end
            end
        end
    end)
    table.sort(allWeapons)
    if #allWeapons==0 then table.insert(allWeapons,"None") weaponKeyMap["None"]="None" end

    local rarityOrder = {"Mythical","Legendary","Rare","Common","Unique","Unobtainable"}
    local function getSlot(cd,cosName)
        local s=tostring(cd.Type or cd.CosmeticType or cd.Category or ""):lower()
        if s:find("skin") then return "Skin" end if s:find("wrap") then return "Wrap" end
        if s:find("charm") then return "Charm" end if s:find("finish") then return "Finisher" end
        local n=cosName:lower()
        if n:find("wrap") then return "Wrap" end if n:find("charm") then return "Charm" end
        if n:find("finish") then return "Finisher" end return "Skin"
    end
    local function getRarity(cd)
        local s=tostring(cd.Rarity or cd.RarityType or cd.Tier or ""):lower()
        if s:find("mythic") then return "Mythical" end if s:find("legend") then return "Legendary" end
        if s:find("rare") then return "Rare" end if s:find("unique") then return "Unique" end
        if s:find("unobtain") then return "Unobtainable" end return "Common"
    end

    local slots = {"Skin","Wrap","Charm","Finisher"}
    local flat  = {} for _,slot in ipairs(slots) do flat[slot]={all={"None"}} for _,r in ipairs(rarityOrder) do flat[slot][r]={} end end
    local perWeapon = {}
    for _,slot in ipairs(slots) do
        perWeapon[slot]={}
        for _,w in ipairs(allWeapons) do
            perWeapon[slot][w]={all={"None"}}
            for _,r in ipairs(rarityOrder) do perWeapon[slot][w][r]={} end
        end
    end
    local cosmeticsBySlot = {} for _,slot in ipairs(slots) do cosmeticsBySlot[slot]={} end

    if CosmeticLibrary.Cosmetics then
        for cosName,cd in pairs(CosmeticLibrary.Cosmetics) do
            local slot=getSlot(cd,cosName) local rarity=getRarity(cd)
            local rawKey=cd.WeaponType or cd.Weapon or cd.ForWeapon or cd.ItemType or cd.AppliesTo
            local wd=rawKey and resolveWeaponName(rawKey) or nil
            table.insert(flat[slot].all,cosName) table.insert(flat[slot][rarity],cosName)
            if wd and perWeapon[slot][wd] then
                table.insert(perWeapon[slot][wd].all,cosName) table.insert(perWeapon[slot][wd][rarity],cosName)
            end
            local cloned=cloneCosmetic(cosName,slot) if cloned then cosmeticsBySlot[slot][cosName]=cloned end
        end
    end
    for _,slot in ipairs(slots) do
        table.sort(flat[slot].all) for _,r in ipairs(rarityOrder) do table.sort(flat[slot][r]) end
        for _,wd in pairs(perWeapon[slot]) do table.sort(wd.all) for _,r in ipairs(rarityOrder) do table.sort(wd[r]) end end
    end

    local savedConfig = loadEquippedConfig()
    for wKeyStr,slots2 in pairs(savedConfig) do
        for slotName,cosName in pairs(slots2) do
            if cosName and cosName~="" then
                local cloned=cosmeticsBySlot[slotName] and cosmeticsBySlot[slotName][cosName]
                if cloned then equipped[wKeyStr]=equipped[wKeyStr] or {} equipped[wKeyStr][slotName]=cloned end
            end
        end
    end
    if next(savedConfig) then
        task.defer(function() pcall(function() DataController.CurrentData:Replicate("WeaponInventory") end) end)
        Notify({Title="Cloakware",Description="Loaded saved skin config!",Time=4})
    end

    local function applyCosmetic(wDisplay,cosName,slot)
        if not wDisplay or wDisplay=="None" then Notify({Title="Cloakware",Description="Select a weapon first!",Time=3}) return end
        local wKey=weaponKeyMap[wDisplay] or wDisplay local wKeyStr=tostring(wKey)
        equipped[wKeyStr]=equipped[wKeyStr] or {}
        if not cosName or cosName=="None" or cosName=="" then
            equipped[wKeyStr][slot]=nil equipped[wKeyStr]["__multi_"..slot]=nil
            if not next(equipped[wKeyStr]) then equipped[wKeyStr]=nil end
            Notify({Title="Cloakware",Description=slot.." removed!",Time=3})
        else
            local cloned=cosmeticsBySlot[slot][cosName] or cloneCosmetic(cosName,slot)
            if cloned then
                equipped[wKeyStr][slot]=cloned equipped[wKeyStr]["__multi_"..slot]=nil
                Notify({Title="Cloakware",Description=slot..": "..cosName,Time=3})
            else Notify({Title="Cloakware",Description="Not found: "..cosName,Time=3}) return end
        end
        task.defer(function() pcall(function() DataController.CurrentData:Replicate("WeaponInventory") end) end)
        task.defer(function() saveEquippedConfig(equipped) end)
    end

    local function applyMultiCosmetics(wDisplay,list,slot)
        if not wDisplay or wDisplay=="None" then Notify({Title="Cloakware",Description="Select a weapon first!",Time=3}) return end
        local wKey=weaponKeyMap[wDisplay] or wDisplay local wKeyStr=tostring(wKey)
        equipped[wKeyStr]=equipped[wKeyStr] or {}
        equipped[wKeyStr][slot]=nil equipped[wKeyStr]["__multi_"..slot]=nil
        local allCloned={} local count=0
        for _,cosName in ipairs(list) do
            if cosName~="None" and cosName~="" then
                local cloned=cosmeticsBySlot[slot][cosName] or cloneCosmetic(cosName,slot)
                if cloned then
                    count+=1 table.insert(allCloned,cloned)
                    local tempKey=wKeyStr.."__rarity_"..slot.."_"..count
                    equipped[tempKey]=equipped[tempKey] or {} equipped[tempKey][slot]=cloned
                end
            end
        end
        if count==0 then Notify({Title="Cloakware",Description="No "..slot.."s found!",Time=3}) return end
        equipped[wKeyStr][slot]=allCloned[1] equipped[wKeyStr]["__multi_"..slot]=allCloned
        task.defer(function() pcall(function() DataController.CurrentData:Replicate("WeaponInventory") end) end)
        task.defer(function() saveEquippedConfig(equipped) end)
        Notify({Title="Cloakware",Description=("Unlocked %d %ss! (%s...)"):format(count,slot,allCloned[1].Name),Time=4})
    end

    local function getList(slot,wDisplay)
        if wDisplay and wDisplay~="None" and perWeapon[slot][wDisplay] and #perWeapon[slot][wDisplay].all>1 then
            return perWeapon[slot][wDisplay]
        end
        return flat[slot]
    end

    local cosLeftSec  = tabs.cosmetics:CreateSection("Unlock by Rarity")
    local cosRightSec = tabs.cosmetics:CreateSection("Browse & Apply", "right")

    local selectedWeapon = {}
    for _, slot in ipairs(slots) do selectedWeapon[slot] = allWeapons[1] or "None" end

    for _, slot in ipairs(slots) do
        local slotLabel = slot
        cosLeftSec:CreateLabel("── "..slotLabel.." ──")
        cosLeftSec:CreateDropdown("Weapon ("..slotLabel..")", allWeapons, function(v) selectedWeapon[slotLabel]=v end, allWeapons[1], false)
        for _,r in ipairs(rarityOrder) do
            local rc = r
            cosLeftSec:CreateButton("Unlock "..r.." "..slotLabel.."s", function()
                local wn = selectedWeapon[slotLabel]
                local list = getList(slotLabel,wn)
                local rl = list[rc] or {}
                if #rl==0 then rl=flat[slotLabel][rc] or {} end
                if #rl==0 then Notify({Title="Cloakware",Description="No "..rc.." "..slotLabel.."s found",Time=3}) return end
                applyMultiCosmetics(wn,rl,slotLabel)
            end)
        end
        cosLeftSec:CreateButton("Unlock ALL "..slotLabel.." Rarities", function()
            local wn = selectedWeapon[slotLabel]
            local list = getList(slotLabel,wn)
            local fullList = {}
            for _,r in ipairs(rarityOrder) do for _,cn in ipairs(list[r] or {}) do table.insert(fullList,cn) end end
            if #fullList==0 then fullList=list.all end
            applyMultiCosmetics(wn,fullList,slotLabel)
        end)
    end

    for _, slot in ipairs(slots) do
        local slotLabel = slot
        local specInput = ""
        cosRightSec:CreateLabel("── "..slotLabel.." ──")
        cosRightSec:CreateTextBox(slotLabel.." Name", "", false, function(v) specInput=v end)
        cosRightSec:CreateButton("Unlock Specific "..slotLabel, function()
            if specInput~="" then applyCosmetic(selectedWeapon[slotLabel],specInput,slotLabel)
            else Notify({Title="Cloakware",Description="Enter a name!",Time=3}) end
        end)
        cosRightSec:CreateButton("Lock "..slotLabel, function() applyCosmetic(selectedWeapon[slotLabel],"None",slotLabel) end)
        cosRightSec:CreateButton("Lock All "..slotLabel.."s", function()
            local wn = selectedWeapon[slotLabel]
            local wKey = tostring(weaponKeyMap[wn] or wn)
            local toRemove = {}
            for k,_ in pairs(equipped) do if k:find(wKey.."__rarity_"..slotLabel) then table.insert(toRemove,k) end end
            for _,k in ipairs(toRemove) do equipped[k]=nil end
            if equipped[wKey] then
                equipped[wKey][slotLabel]=nil equipped[wKey]["__multi_"..slotLabel]=nil
                if not next(equipped[wKey]) then equipped[wKey]=nil end
            end
            task.defer(function() pcall(function() DataController.CurrentData:Replicate("WeaponInventory") end) end)
            task.defer(function() saveEquippedConfig(equipped) end)
            Notify({Title="Cloakware",Description="Locked all "..slotLabel.."s",Time=3})
        end)
        cosRightSec:CreateButton("Random "..slotLabel, function()
            local wn = selectedWeapon[slotLabel]
            local list = getList(slotLabel,wn).all
            local valid = {}
            for _,n in ipairs(list) do if n~="None" then table.insert(valid,n) end end
            if #valid>0 then applyCosmetic(wn,valid[math.random(1,#valid)],slotLabel) end
        end)
        local selectedCos = "None"
        cosRightSec:CreateDropdown("Browse "..slotLabel.."s", getList(slotLabel,allWeapons[1] or "None").all, function(v) selectedCos=v end, "None", false)
        cosRightSec:CreateButton("Apply Selected "..slotLabel, function() applyCosmetic(selectedWeapon[slotLabel],selectedCos,slotLabel) end)
        cosRightSec:CreateButton("Save "..slotLabel.." Config", function()
            saveEquippedConfig(equipped) Notify({Title="Cloakware",Description=slotLabel.." config saved!",Time=3})
        end)
        cosRightSec:CreateButton("Clear "..slotLabel.." Config", function()
            local wn = selectedWeapon[slotLabel]
            local wKey = tostring(weaponKeyMap[wn] or wn)
            local toRemove = {}
            for k,_ in pairs(equipped) do if k:find(wKey.."__rarity_"..slotLabel) then table.insert(toRemove,k) end end
            for _,k in ipairs(toRemove) do equipped[k]=nil end
            if equipped[wKey] then
                equipped[wKey][slotLabel]=nil equipped[wKey]["__multi_"..slotLabel]=nil
                if not next(equipped[wKey]) then equipped[wKey]=nil end
            end
            saveEquippedConfig(equipped)
            task.defer(function() pcall(function() DataController.CurrentData:Replicate("WeaponInventory") end) end)
            Notify({Title="Cloakware",Description=slotLabel.." config cleared!",Time=3})
        end)
    end

    local FighterController
    pcall(function() FighterController=require(controllers:WaitForChild("FighterController",10)) end)
    if hookmetamethod then
        local remotes = ReplicatedStorage:FindFirstChild("Remotes")
        local dataRemotes = remotes and remotes:FindFirstChild("Data")
        local equipRemote = dataRemotes and dataRemotes:FindFirstChild("EquipCosmetic")
        local favoriteRemote = dataRemotes and dataRemotes:FindFirstChild("FavoriteCosmetic")
        local repRemotes = remotes and remotes:FindFirstChild("Replication")
        local fighterRemotes = repRemotes and repRemotes:FindFirstChild("Fighter")
        local useItemRemote = fighterRemotes and fighterRemotes:FindFirstChild("UseItem")
        if equipRemote then
            local oldNC
            oldNC = hookmetamethod(game,"__namecall",function(self,...)
                if getnamecallmethod()~="FireServer" then return oldNC(self,...) end
                local args = {...}
                if useItemRemote and self==useItemRemote then
                    local objectID = args[1]
                    if FighterController then
                        pcall(function()
                            local fighter=FighterController:GetFighter(player)
                            if fighter and fighter.Items then
                                for _,item in pairs(fighter.Items) do
                                    if item:Get("ObjectID")==objectID then lastUsedWeapon=item.Name break end
                                end
                            end
                        end)
                    end
                end
                if self==equipRemote then
                    local wn,ct,cn,opts=args[1],args[2],args[3],args[4] or {}
                    if cn and cn~="None" and cn~="" then
                        local inv=DataController:Get("CosmeticInventory")
                        if inv and rawget(inv,cn) then return oldNC(self,...) end
                    end
                    local ws=tostring(wn) equipped[ws]=equipped[ws] or {}
                    if not cn or cn=="None" or cn=="" then
                        equipped[ws][ct]=nil equipped[ws]["__multi_"..ct]=nil
                        if not next(equipped[ws]) then equipped[ws]=nil end
                    else
                        local cloned=(cosmeticsBySlot[ct] and cosmeticsBySlot[ct][cn])
                            or cloneCosmetic(cn,ct,{inverted=opts.IsInverted,favoritesOnly=opts.OnlyUseFavorites})
                        if cloned then equipped[ws][ct]=cloned end
                    end
                    task.defer(function() pcall(function() DataController.CurrentData:Replicate("WeaponInventory") end) end)
                    task.defer(function() saveEquippedConfig(equipped) end)
                    return
                end
                if self==favoriteRemote then
                    favorites[args[1]]=favorites[args[1]] or {}
                    favorites[args[1]][args[2]]=args[3] or nil
                    task.spawn(function() pcall(function() DataController.CurrentData:Replicate("FavoritedCosmetics") end) end)
                    return
                end
                return oldNC(self,...)
            end)
        end
    end

    local ClientItem
    pcall(function() ClientItem=require(playerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem) end)
    if ClientItem and ClientItem._CreateViewModel then
        local origCVM = ClientItem._CreateViewModel
        ClientItem._CreateViewModel = function(self, viewmodelRef)
            local wn=self.Name local wp=self.ClientFighter and self.ClientFighter.Player
            constructingWeapon=(wp==player) and wn or nil
            if wp==player and equipped[wn] and equipped[wn].Skin and viewmodelRef then
                pcall(function()
                    local dk,sk,nk=self:ToEnum("Data"),self:ToEnum("Skin"),self:ToEnum("Name")
                    if viewmodelRef[dk] then viewmodelRef[dk][sk]=equipped[wn].Skin viewmodelRef[dk][nk]=equipped[wn].Skin.Name
                    elseif viewmodelRef.Data then viewmodelRef.Data.Skin=equipped[wn].Skin viewmodelRef.Data.Name=equipped[wn].Skin.Name end
                end)
            end
            local result=origCVM(self,viewmodelRef) constructingWeapon=nil return result
        end
    end

    local vmMod = playerScripts.Modules.ClientReplicatedClasses.ClientFighter.ClientItem:FindFirstChild("ClientViewModel")
    if vmMod then
        local CVM pcall(function() CVM=require(vmMod) end)
        if CVM then
            if CVM.GetWrap then
                local origGW=CVM.GetWrap
                CVM.GetWrap=function(self)
                    local wn=self.ClientItem and self.ClientItem.Name
                    local wp=self.ClientItem and self.ClientItem.ClientFighter and self.ClientItem.ClientFighter.Player
                    if wn and wp==player and equipped[wn] and equipped[wn].Wrap then return equipped[wn].Wrap end
                    return origGW(self)
                end
            end
            local origNew=CVM.new
            CVM.new=function(replicatedData,clientItem)
                local wp=clientItem.ClientFighter and clientItem.ClientFighter.Player
                local wn=constructingWeapon or clientItem.Name
                if wp==player and equipped[wn] then
                    pcall(function()
                        local RC=require(ReplicatedStorage.Modules.ReplicatedClass) local dk=RC:ToEnum("Data")
                        replicatedData[dk]=replicatedData[dk] or {} local c=equipped[wn]
                        if c.Skin  then replicatedData[dk][RC:ToEnum("Skin")] =c.Skin  end
                        if c.Wrap  then replicatedData[dk][RC:ToEnum("Wrap")] =c.Wrap  end
                        if c.Charm then replicatedData[dk][RC:ToEnum("Charm")]=c.Charm end
                    end)
                end
                local result=origNew(replicatedData,clientItem)
                if wp==player and equipped[wn] and equipped[wn].Wrap and result._UpdateWrap then
                    result:_UpdateWrap()
                    task.delay(0.1,function() if not result._destroyed then result:_UpdateWrap() end end)
                end
                return result
            end
        end
    end

    if ItemLibrary and ItemLibrary.GetViewModelImageFromWeaponData then
        local origGVI=ItemLibrary.GetViewModelImageFromWeaponData
        ItemLibrary.GetViewModelImageFromWeaponData=function(self,wd,highRes)
            if not wd then return origGVI(self,wd,highRes) end
            local wn=wd.Name
            local show=(wd.Skin and equipped[wn] and wd.Skin==equipped[wn].Skin)
                or (viewingProfile==player and equipped[wn] and equipped[wn].Skin)
            if show and equipped[wn] and equipped[wn].Skin then
                local si=self.ViewModels[equipped[wn].Skin.Name]
                if si then return si[highRes and "ImageHighResolution" or "Image"] or si.Image end
            end
            return origGVI(self,wd,highRes)
        end
    end

    pcall(function()
        local VP=require(playerScripts.Modules.Pages.ViewProfile)
        if VP and VP.Fetch then local origF=VP.Fetch VP.Fetch=function(self,tp) viewingProfile=tp return origF(self,tp) end end
    end)

    local CE pcall(function() CE=require(playerScripts.Modules.ClientReplicatedClasses.ClientEntity) end)
    if CE and CE.ReplicateFromServer then
        local origRFS=CE.ReplicateFromServer
        CE.ReplicateFromServer=function(self,action,...)
            if action=="FinisherEffect" then
                local args={...} local kn=args[3] local dk=kn
                if type(kn)=="userdata" and EnumLibrary and EnumLibrary.FromEnum then
                    local ok2,dec=pcall(EnumLibrary.FromEnum,EnumLibrary,kn) if ok2 and dec then dk=dec end
                end
                local isOurs=tostring(dk)==player.Name or tostring(dk):lower()==player.Name:lower()
                if isOurs and lastUsedWeapon and equipped[lastUsedWeapon] and equipped[lastUsedWeapon].Finisher then
                    local fd=equipped[lastUsedWeapon].Finisher local fe=fd.Enum
                    if not fe and EnumLibrary then
                        local ok2,res=pcall(EnumLibrary.ToEnum,EnumLibrary,fd.Name) if ok2 and res then fe=res end
                    end
                    if fe then args[1]=fe return origRFS(self,action,unpack(args)) end
                end
            end
            return origRFS(self,action,...)
        end
    end

    Notify({Title="Cloakware", Description="Ready!", Time=4})
end)
