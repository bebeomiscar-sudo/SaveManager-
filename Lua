local function StopCSync()
    rageState.csyncActive = false
    orbitState.active     = false
    orbitState.serverPos  = Vector3.new()
    if orbitState.connection then
        orbitState.connection:Disconnect()
        orbitState.connection = nil
    end
end

local function StartCSync(targetChar)
    StopCSync()
    rageState.csyncActive = true
    orbitState.active     = true
    orbitState.angle      = 0

    orbitState.connection = Track(RunService.Heartbeat:Connect(function(dt)
        if not rageState.csyncActive then StopCSync();return end
        if rageState.immune then StopCSync();return end
        if not targetChar or not ValidChar(targetChar) then StopCSync();return end

        local myChar = lp.Character
        if not myChar then StopCSync();return end

        local lfEntity = nil
        pcall(function()
            if FighterController and FighterController.LocalFighter then
                lfEntity = FighterController.LocalFighter.Entity
            end
        end)

        if RageCfg.VoidSpam and rageState.voidPhase == "hide" then
            local rx = math.random(-10000,10000)
            local rz = math.random(-10000,10000)
            orbitState.serverPos = Vector3.new(rx,-99999999,rz)
            pcall(function()
                if lfEntity and lfEntity.RootPart then
                    lfEntity.RootPart.CFrame = CFrame.new(orbitState.serverPos)
                else
                    local hrp = myChar:FindFirstChild("HumanoidRootPart")
                    if hrp then hrp.CFrame = CFrame.new(orbitState.serverPos) end
                end
            end)
            return
        end

        local targetHRP = targetChar:FindFirstChild("HumanoidRootPart")
        if not targetHRP then return end

        orbitState.angle = orbitState.angle + (RageCfg.OrbitSpeed * dt)
        local offset = Vector3.new(
            math.cos(orbitState.angle) * RageCfg.OrbitRadius,
            RageCfg.OrbitHeight,
            math.sin(orbitState.angle) * RageCfg.OrbitRadius
        )
        orbitState.serverPos = targetHRP.Position + offset

        local newCF = CFrame.new(orbitState.serverPos)
        pcall(function()
            if lfEntity and lfEntity.RootPart then
                local dist = (newCF.Position - lfEntity.RootPart.Position).Magnitude
                if dist < 2000 then lfEntity.RootPart.CFrame = newCF end
            else
                local hrp = myChar:FindFirstChild("HumanoidRootPart")
                if hrp then
                    local dist = (newCF.Position - hrp.Position).Magnitude
                    if dist < 2000 then hrp.CFrame = newCF end
                end
            end
        end)
    end))
end

local function HideShot()
    if not RageCfg.VoidSpam then return end
    rageState.voidPhase = "hide"
    task.delay(RageCfg.HideRange, function()
        rageState.voidPhase = "attack"
        task.delay(RageCfg.AttackRange, function()
            rageState.voidPhase = "idle"
        end)
    end)
end

local function StartRagebot()
    if rageConn then rageConn:Disconnect();rageConn=nil end
    rageState.running = false

    rageConn = Track(RunService.Heartbeat:Connect(function()
        if not RageCfg.Enabled or rageState.running then return end

        local lf, item = GetEquipped()
        if not lf or not item then return end

        local targetChar = RageGetTarget()
        if not targetChar then
            RageCfg.Phase = "idle"
            if orbitState.active then StopCSync() end
            return
        end

        if RageCfg.CSyncEnabled and not orbitState.active then
            StartCSync(targetChar)
        elseif not RageCfg.CSyncEnabled and orbitState.active then
            StopCSync()
        end

        if RageCfg.VoidSpam and rageState.voidPhase == "hide" then
            RageCfg.Phase = "hiding"
            return
        end

        RageCfg.Phase     = "attacking"
        rageState.running = true

        task.spawn(function()
            local ok, err2 = pcall(function()
                AutoShoot(targetChar, item, lf)
                HideShot()
                task.wait(RageCfg.AttackRange)
            end)
            if not ok then warn("[Ragebot] Error: "..tostring(err2)) end
            RageCfg.Phase     = "idle"
            rageState.running = false
        end)
    end))
end

local function StopRagebot()
    if rageConn then rageConn:Disconnect();rageConn=nil end
    StopCSync()
    RageCfg.Enabled     = false
    RageCfg.Phase       = "idle"
    rageState.running   = false
    rageState.voidPhase = "idle"
end

