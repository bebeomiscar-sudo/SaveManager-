-- BOX ESP
local boxESPEnabled = false
local boxESPConns = {}
local boxESPDrawings = {}
local boxESPColor = Color3.fromRGB(255, 255, 255)
local boxESPThickness = 2

local function createBoxDrawing()
    local box = {}
    for i = 1, 4 do
        local line = Drawing.new("Line")
        line.Visible = false
        line.Color = boxESPColor
        line.Thickness = boxESPThickness
        line.Transparency = 1
        box[i] = line
    end
    return box
end

local function removeBoxESP()
    for _, conn in pairs(boxESPConns) do pcall(function() conn:Disconnect() end) end
    boxESPConns = {}
    for _, playerBox in pairs(boxESPDrawings) do
        for _, line in pairs(playerBox) do pcall(function() line:Remove() end) end
    end
    boxESPDrawings = {}
end

sec_esp_main:CreateLabel("── Box ESP ──")
sec_esp_main:CreateToggle("Box ESP", false, function(value)
    boxESPEnabled = value
    if not value then removeBoxESP() Notify({Title="Cloakware", Description="Box ESP OFF", Time=3}) return end
    local Players = game:GetService("Players")
    local RunService = game:GetService("RunService")
    local LP = Players.LocalPlayer
    local Camera = workspace.CurrentCamera
    local conn = RunService.RenderStepped:Connect(function()
        if not boxESPEnabled then return end
        for _, player in ipairs(Players:GetPlayers()) do
            if player == LP then continue end
            if espTeamCheck and IsTeamMate(player) then
                if boxESPDrawings[player] then for _, line in pairs(boxESPDrawings[player]) do line.Visible = false end end
                continue
            end
            if player.Character and player.Character:FindFirstChild("Humanoid") and player.Character:FindFirstChild("Head") and player.Character:FindFirstChild("HumanoidRootPart") then
                local char = player.Character
                local head = char.Head
                local hrp = char.HumanoidRootPart
                if not boxESPDrawings[player] then boxESPDrawings[player] = createBoxDrawing() end
                local box = boxESPDrawings[player]
                local headPos = head.Position + Vector3.new(0, 0.5, 0)
                local feetPos = hrp.Position - Vector3.new(0, 3, 0)
                local headScreen, headVisible = Camera:WorldToViewportPoint(headPos)
                local feetScreen, feetVisible = Camera:WorldToViewportPoint(feetPos)
                if headVisible or feetVisible then
                    local height = math.abs(headScreen.Y - feetScreen.Y)
                    local width = height * 0.65
                    box[1].From = Vector2.new(headScreen.X - width/2, headScreen.Y)
                    box[1].To = Vector2.new(headScreen.X + width/2, headScreen.Y)
                    box[2].From = Vector2.new(headScreen.X + width/2, headScreen.Y)
                    box[2].To = Vector2.new(feetScreen.X + width/2, feetScreen.Y)
                    box[3].From = Vector2.new(feetScreen.X + width/2, feetScreen.Y)
                    box[3].To = Vector2.new(feetScreen.X - width/2, feetScreen.Y)
                    box[4].From = Vector2.new(feetScreen.X - width/2, feetScreen.Y)
                    box[4].To = Vector2.new(headScreen.X - width/2, headScreen.Y)
                    for _, line in pairs(box) do line.Color = boxESPColor line.Thickness = boxESPThickness line.Visible = true end
                else for _, line in pairs(box) do line.Visible = false end end
            elseif boxESPDrawings[player] then for _, line in pairs(boxESPDrawings[player]) do line.Visible = false end end
        end
    end)
    table.insert(boxESPConns, conn)
    table.insert(boxESPConns, Players.PlayerRemoving:Connect(function(player)
        if boxESPDrawings[player] then for _, line in pairs(boxESPDrawings[player]) do pcall(function() line:Remove() end) end boxESPDrawings[player] = nil end
    end))
    Notify({Title="Cloakware", Description="Box ESP ON", Time=3})
end)
