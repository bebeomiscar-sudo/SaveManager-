end

local function HideESP(obj)
    for _,l in ipairs(obj.Lines) do l.Visible=false end
    obj.FilledBox.Visible=false;obj.NameLabel.Visible=false;obj.HealthLabel.Visible=false;obj.DistLabel.Visible=false
end

local function GetBB2D(char)
    local hrp=char:FindFirstChild("HumanoidRootPart");if not hrp then return nil end
    local ok,_,size=pcall(function() return char:GetBoundingBox() end)
    local hw=ok and (size and size.X/2 or 1.1) or 1.1;local hh=ok and (size and size.Y/2 or 1.5) or 1.5
    local c=hrp.Position
    local corners={
        c+Vector3.new(-hw,-hh,-hw),c+Vector3.new(hw,-hh,-hw),c+Vector3.new(hw,-hh,hw),c+Vector3.new(-hw,-hh,hw),
        c+Vector3.new(-hw,hh,-hw), c+Vector3.new(hw,hh,-hw), c+Vector3.new(hw,hh,hw), c+Vector3.new(-hw,hh,hw),
    }
    local screen={}
    for _,corner in ipairs(corners) do
        local sp,on=cam:WorldToViewportPoint(corner);if not on then return nil end
        table.insert(screen,Vector2.new(sp.X,sp.Y))
    end
    return screen
end

local function UpdateESP()
    local myHRP=lp.Character and lp.Character:FindFirstChild("HumanoidRootPart")
    for _,player in ipairs(Players:GetPlayers()) do
        if player==lp then continue end
        local obj=ESPObjects[player];if not obj then continue end
        if not ESPCfg.Enabled or not IsValidTarget(player) then HideESP(obj);continue end
        local char=player.Character;local hrp=char and char:FindFirstChild("HumanoidRootPart")
        local hum=char and char:FindFirstChildOfClass("Humanoid");if not hrp or not hum then HideESP(obj);continue end
        local dist=myHRP and (myHRP.Position-hrp.Position).Magnitude or 0
        if dist>ESPCfg.MaxDist then HideESP(obj);continue end
        local isTeam=SameTeam(player);if ESPCfg.TeamCheck and isTeam then HideESP(obj);continue end
        local bc=isTeam and ESPCfg.TeamColor or ESPCfg.BoxColor
        local sc=GetBB2D(char);if not sc then HideESP(obj);continue end
        if ESPCfg.ShowBox then for i,e in ipairs(EDGES) do obj.Lines[i].From=sc[e[1]];obj.Lines[i].To=sc[e[2]];obj.Lines[i].Color=bc;obj.Lines[i].Visible=true end
        else for _,l in ipairs(obj.Lines) do l.Visible=false end end
        if ESPCfg.Filled and ESPCfg.ShowBox then
            local mnX,mnY=math.huge,math.huge;local mxX,mxY=-math.huge,-math.huge
            for _,s in ipairs(sc) do mnX=math.min(mnX,s.X);mnY=math.min(mnY,s.Y);mxX=math.max(mxX,s.X);mxY=math.max(mxY,s.Y) end
            obj.FilledBox.Position=Vector2.new(mnX,mnY);obj.FilledBox.Size=Vector2.new(mxX-mnX,mxY-mnY)
            obj.FilledBox.Color=bc;obj.FilledBox.Transparency=1-ESPCfg.FilledOpacity;obj.FilledBox.Visible=true
        else obj.FilledBox.Visible=false end
        local np=sc[5]-Vector2.new(0,18)
        if ESPCfg.ShowName then obj.NameLabel.Text=player.DisplayName;obj.NameLabel.Position=np;obj.NameLabel.Color=ESPCfg.NameColor;obj.NameLabel.Visible=true else obj.NameLabel.Visible=false end
        if ESPCfg.ShowHealth then
            local hp=math.floor(hum.Health);local mh=math.floor(hum.MaxHealth);local r=math.clamp(hum.Health/math.max(hum.MaxHealth,1),0,1)
            obj.HealthLabel.Text=hp.." / "..mh;obj.HealthLabel.Position=np-Vector2.new(0,14)
            obj.HealthLabel.Color=Color3.fromRGB(math.floor((1-r)*255),math.floor(r*255),0);obj.HealthLabel.Visible=true
        else obj.HealthLabel.Visible=false end
        if ESPCfg.ShowDist then obj.DistLabel.Text=math.floor(dist).." studs";obj.DistLabel.Position=sc[1]+Vector2.new(0,4);obj.DistLabel.Visible=true else obj.DistLabel.Visible=false end
    end
end

